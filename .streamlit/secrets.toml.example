# Streamlit Community Cloud secrets.
# Copy this into the app's "Secrets" box (Manage app → Settings → Secrets),
# OR save locally as .streamlit/secrets.toml (git-ignored) for local testing.
#
# All keys are OPTIONAL — the deployed app self-bootstraps a synthetic demo
# dataset, so it works with no secrets at all. Add keys only if you later wire
# in a live-harvest button.

NVD_API_KEY = ""
OTX_API_KEY = ""
ABUSEIPDB_API_KEY = ""
CTI_LOG_LEVEL = "INFO"
