# Copy to .env and fill in. All keys are OPTIONAL — the pipeline degrades
# gracefully when a source is unavailable (NVD and CISA KEV work key-less).

# NVD API key — https://nvd.nist.gov/developers/request-an-api-key
# Strongly recommended: relaxes rate limit from 5 to 50 requests / 30s.
NVD_API_KEY=

# AlienVault OTX — https://otx.alienvault.com/api  (needed for IOC harvest)
OTX_API_KEY=

# AbuseIPDB — https://www.abuseipdb.com/account/api  (IP reputation scores)
ABUSEIPDB_API_KEY=

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
CTI_LOG_LEVEL=INFO
